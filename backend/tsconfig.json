{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",

    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node16",
    "resolveJsonModule": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,
    "forceConsistentCasingInFileNames": true,

    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,
    "declaration": true
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}